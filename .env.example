NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

WEBSITE_CONNECTOR_SECRET=replace-with-a-long-random-secret
WEBSITE_CONNECTOR_PROJECT_ID=

WILDSAURA_FIREBASE_PROJECT_ID=wildsaura-1ef8a
WILDSAURA_FIREBASE_API_KEY=
WILDSAURA_FIREBASE_SERVICE_ACCOUNT_JSON=
WEBSITE_REPLY_DISPLAY_NAME=Wildsaura Team
WEBSITE_REPLY_AVATAR_COLOR=#10b981
WEBSITE_REPLY_AVATAR_URL=

# Custom IMAP/SMTP email connector.
# Store only secrets here/server env, never in Supabase or browser forms.
EMAIL_CONNECTOR_ADDRESS=help@wildsaura.com
EMAIL_CONNECTOR_USERNAME=help@wildsaura.com
EMAIL_CONNECTOR_PASSWORD=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_ENCRYPTION=ssl_tls
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_ENCRYPTION=ssl_tls

# Meta Facebook / Instagram connector skeleton.
# Store app secrets only in server env, never in Supabase or browser forms.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_REDIRECT_URI=

OPENROUTER_API_KEY=
OPENROUTER_GPT_MODEL=openai/gpt-4o-mini
OPENROUTER_CODEX_MODEL=openai/gpt-5-codex
OPENROUTER_GEMINI_MODEL=google/gemini-2.5-flash
OPENROUTER_CLAUDE_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_DEEPSEEK_MODEL=deepseek/deepseek-chat

# Local/offline AI through OpenAI-compatible endpoints.
# LM Studio default:
LOCAL_AI_ENDPOINT_MODE=openai
LOCAL_AI_BASE_URL=http://localhost:1234/v1
# Ollama OpenAI-compatible default:
# LOCAL_AI_BASE_URL=http://localhost:11434/v1
LOCAL_AI_API_KEY=local
LOCAL_AI_MODEL=llama-3.1-8b-instruct

# LM Studio REST API v1 mode, if your server shows /api/v1/chat examples:
# LOCAL_AI_ENDPOINT_MODE=lmstudio
# LOCAL_AI_BASE_URL=http://localhost:1234
# LOCAL_AI_API_KEY=your-lm-studio-token
# LOCAL_AI_MODEL=google/gemma-4-e4b
